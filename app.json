{
  "expo": {
    "name": "CalTrack",
    "slug": "caltrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "caltrack",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "userInterfaceStyle": "dark",
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.caltrack"
    },
    "android": {
      "userInterfaceStyle": "dark",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "splash": {
      "backgroundColor": "#000000"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow caltrack to scan barcodes on food packages."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
